# ── Feature flags ────────────────────────────────────────────────────────────
USE_MOCK_DATA=true
DEBUG=false
LOG_LEVEL=INFO

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=

# ── Azure ─────────────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_BILLING_ACCOUNT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Recommendation thresholds ────────────────────────────────────────────────
IDLE_CPU_THRESHOLD_PERCENT=5.0
IDLE_LOOKBACK_DAYS=7
RDS_CPU_THRESHOLD_PERCENT=20.0
RDS_CONNECTIONS_THRESHOLD=5
